# Required: main pipeline config path.
MINIFLOW_CONFIG=configs/baseline.yml
MINIFLOW_REQUEST_TIMEOUT_SECONDS=120

# Max upload payload for /s2s in bytes (10 MiB default).
MINIFLOW_MAX_AUDIO_UPLOAD_BYTES=10485760
# Required: release identifier (pseudo for now).
# TODO: generate immutable RELEASE_ID in CI/CD (git SHA or image tag).
RELEASE_ID=dev-pseudo
